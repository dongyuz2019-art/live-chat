<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Live Chat</title>
    <link rel="stylesheet" href="/css/chat.css">
</head>
<body>
    <div class="chat-page">
        <div class="chat-history" id="chatHistory"></div>
        <div class="chat-form">
            <form action="">
                <input type="text">
                <button>Send</button>
            </form>
        </div>
    </div>
    <script>
        async function poll() {
            const response = await fetch('/poll');
            const data = await response.json();
            document.getElementById('chatHistory').innerHTML = data.history
            .map(his => `<p>${his.nickname}: ${his.message}</p>`)
            .join('');

            setTimeout(poll, 2000);
        }

        document.addEventListener('DOMContentLoaded', () => {
            poll();
        });
    </script>
</body>
</html>